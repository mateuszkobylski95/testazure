events {}

http {

    server_names_hash_bucket_size 128;

    server {

        listen 80;

        server_name
            {{ bootstrap_config.WG_DOMAIN }}
            {% if bootstrap_config.DEPLOYMENT_MODE == "dual" %}
            {{ bootstrap_config.KUMA_DOMAIN }}
            {% endif %}
            {% for domain in service_domains %}
            {{ domain }}
            {% endfor %};

        location ^~ /.well-known/acme-challenge/ {
            root /var/www/certbot;
        }

        location / {
            return 200 "bootstrap";
        }
    }
}
