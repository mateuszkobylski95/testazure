services:

  wg-easy:
    image: ghcr.io/wg-easy/wg-easy:15
    container_name: wg-easy

    restart: unless-stopped

    env_file:
      - .env

    cap_add:
      - NET_ADMIN
      - SYS_MODULE

    sysctls:
      - net.ipv4.ip_forward=1
      - net.ipv4.conf.all.src_valid_mark=1

    volumes:
      - /opt/{{ bootstrap_config.REPO_NAME }}/data/wireguard:/etc/wireguard
      - /lib/modules:/lib/modules:ro

    ports:
      - "51820:51820/udp"

    networks:
      internal:
        ipv4_address: "{{ bootstrap_config.WG_EASY_IP }}"

  uptime-kuma:
    image: louislam/uptime-kuma:2
    container_name: uptime-kuma

    restart: unless-stopped

    volumes:
      - /opt/{{ bootstrap_config.REPO_NAME }}/data/kuma:/app/data

    networks:
      internal:
        ipv4_address: "{{ bootstrap_config.KUMA_IP }}"

  nginx:
    image: nginx:alpine
    container_name: nginx

    restart: unless-stopped


    ports:
        - "80:80"
        - "443:443"
{% if bootstrap_config.DEPLOYMENT_MODE == "single" %}
        - "8443:8443"
{% endif %}
{% for service in vpn_services %}
{% if not service.has_domain %}
        - "{{ service.public_port }}:{{ service.public_port }}"
{% endif %}
{% endfor %}

    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/.htpasswd:/etc/nginx/.htpasswd:ro
      - ./certbot/conf:/etc/letsencrypt
      - ./certbot/www:/var/www/certbot

    networks:
      internal:
        ipv4_address: "{{ bootstrap_config.NGINX_IP }}"

  certbot:
    image: certbot/certbot
    container_name: certbot

    volumes:
      - ./certbot/conf:/etc/letsencrypt
      - ./certbot/www:/var/www/certbot

networks:
  internal:
    driver: bridge
    ipam:
      config:
        - subnet: "{{ bootstrap_config.DOCKER_SUBNET }}"
